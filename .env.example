# Backend Railway URL — override per environment in your hosting provider.
VITE_API_BASE_URL=https://gtm-engine-sales-planning-tofu-production.up.railway.app

# Async job polling — set to "false" to fall back to legacy sync /api/run-plan.
VITE_USE_ASYNC_JOBS=true

# Job poll interval in ms. Default 1500.
VITE_JOB_POLL_INTERVAL_MS=1500

# Max time the frontend will wait for a job before giving up (ms).
VITE_JOB_POLL_TIMEOUT_MS=600000
